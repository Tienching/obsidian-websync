{
  "name": "websync",
  "version": "0.1.6",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "npm run build:server && npm run build:plugin",
    "build:plugin": "node scripts/build-plugin.mjs",
    "build:server": "node scripts/build-server.mjs",
    "install:plugin": "npm run build:plugin && node scripts/install-plugin.mjs",
    "seed:cos": "node scripts/seed-cos-direct.mjs",
    "seed:vault": "node scripts/seed-vault.mjs",
    "test": "vitest run",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "cos-nodejs-sdk-v5": "^2.14.7",
    "dotenv": "^16.4.7",
    "ws": "^8.18.0"
  },
  "overrides": {
    "ajv": "^8.18.0",
    "ajv-formats": "^2.1.1",
    "fast-xml-parser": "^4.5.5",
    "form-data": "^2.5.5",
    "qs": "^6.14.1",
    "tough-cookie": "^4.1.4"
  },
  "devDependencies": {
    "@types/node": "^22.10.2",
    "@types/ws": "^8.5.13",
    "esbuild": "^0.24.2",
    "obsidian": "^1.7.2",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8"
  }
}
