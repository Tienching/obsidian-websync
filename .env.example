# OBS_SYNC_PROXY_TARGET=http://127.0.0.1:52120

COS_BUCKET=your-cos-bucket
COS_REGION=ap-guangzhou
COS_PREFIX=_websync
COS_SECRET_ID=change-me
COS_SECRET_KEY=change-me
