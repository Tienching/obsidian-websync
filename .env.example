OBS_SYNC_HOST=127.0.0.1
OBS_SYNC_PORT=5212
OBS_SYNC_VAULT_ID=default
OBS_SYNC_TOKEN=change-me
OBS_SYNC_DATA_DIR=/home/ubuntu/obsidian-sync/data
